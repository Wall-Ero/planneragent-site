{
  "$schema": "node_modules/wrangler/config-schema.json",

  "name": "planneragent-core",
  "main": "src/worker.ts",
  "compatibility_date": "2026-01-02",

  // ======================================================
  // ENV VARS (Governance + LLM Layer)
  // ======================================================
  "vars": {
    // 🔐 Snapshot signing key (MANDATORY)
    // Used to sign and verify constitutional snapshots.
    // Must NEVER be empty.
    "SNAPSHOT_HMAC_SECRET": "planneragent-dev-hmac-secret-2026",

    // 🤖 LLM Layer (if used)
    "OPENROUTER_API_KEY": "sk-or-XXXXXXXXXXXX"
  },

  // ======================================================
  // D1 DATABASES
  // ======================================================
  "d1_databases": [
    {
      "binding": "POLICIES_DB",
      "database_name": "planneragent-policies",
      "database_id": "d1e3200f-93d7-4cc0-ad69-7f76ecc0ec8f"
    }
  ]
}